[init]
	defaultBranch = master
[user]
	name = Ambrosini Nico (IT-PTR-CEN1-BDE4)
	mail = nico.ambrosini@sbb.ch
	email = nico.ambrosini@sbb.ch
[pull]
	rebase = false
[core]
	autocrlf = input
    editor = nvim
  pager = delta
[commit]
    template = /Users/nambrosini/.commitMsg
[push]
	autoSetupRemote = true

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[merge]
  confictstyle = diff3

[diff]
  colorMoved = default
